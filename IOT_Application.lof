\contentsline {figure}{\numberline {1}{\ignorespaces Bức tranh tổng thể cho bài toán Vaccine Cold Chain Monitoring: nhiều điểm đo (sender) gửi telemetry về một gateway receiver, sau đó đồng bộ cloud để giám sát, cảnh báo và truy vết.}}{3}{figure.caption.3}%
\contentsline {figure}{\numberline {2}{\ignorespaces Sơ đồ mạng nội bộ cho kịch bản chuỗi lạnh vaccine: receiver vừa phát SoftAP phục vụ vận hành tại chỗ vừa kết nối hạ tầng Wi-Fi, sender gửi telemetry về gateway để hợp nhất và đẩy cloud.}}{5}{figure.caption.4}%
\contentsline {figure}{\numberline {3}{\ignorespaces Sơ đồ tách \textit {data plane} và \textit {control plane} giúp nhận diện rõ hai loại luồng trong hệ thống.}}{10}{figure.caption.5}%
\contentsline {figure}{\numberline {4}{\ignorespaces Kiến trúc module của sender gồm các khối trạng thái, mô phỏng, AI, transport, lưu trữ và giao diện web.}}{10}{figure.caption.6}%
\contentsline {figure}{\numberline {5}{\ignorespaces Kiến trúc module của receiver gồm runtime, transport, cloud gateway, lưu trữ và giao diện web.}}{11}{figure.caption.7}%
\contentsline {figure}{\numberline {6}{\ignorespaces Flowchart phần khởi tạo và vòng lặp sender. Sơ đồ cho thấy sender liên tục mô phỏng cảm biến, chạy AI và duy trì mạng.}}{12}{figure.caption.8}%
\contentsline {figure}{\numberline {7}{\ignorespaces Pipeline TinyML trên sender: từ dữ liệu mô phỏng sang tensor input, qua bộ thông dịch TFLite Micro, rồi trả ra điểm bất thường và nhãn trạng thái.}}{14}{figure.caption.9}%
\contentsline {figure}{\numberline {8}{\ignorespaces Mô hình logic của TFLite được sử dụng ở mức báo cáo: hai đầu vào đặc trưng và một đầu ra điểm bất thường.}}{14}{figure.caption.10}%
\contentsline {figure}{\numberline {9}{\ignorespaces Cơ chế WebSocket snapshot của sender và receiver, cho phép web UI nhận trạng thái thời gian thực mà không cần tải lại trang.}}{15}{figure.caption.11}%
\contentsline {figure}{\numberline {10}{\ignorespaces Giao diện web sender ESP32-01 trong thực nghiệm.}}{16}{figure.caption.12}%
\contentsline {figure}{\numberline {11}{\ignorespaces Giao diện web sender ESP32-02 trong thực nghiệm.}}{17}{figure.caption.13}%
\contentsline {figure}{\numberline {12}{\ignorespaces Dialog cài đặt Wi-Fi và receiver của sender.}}{18}{figure.caption.14}%
\contentsline {figure}{\numberline {13}{\ignorespaces Cấu trúc lưu trữ LittleFS dùng chung cho cả sender và receiver: tệp cấu hình, danh sách sender đã đăng ký và giao diện web tĩnh.}}{19}{figure.caption.15}%
\contentsline {figure}{\numberline {14}{\ignorespaces Flowchart phần khởi tạo và vòng lặp receiver. Sơ đồ cho thấy receiver đồng thời xử lý DNS, TCP, Wi-Fi, MQTT và snapshot cho UI.}}{20}{figure.caption.16}%
\contentsline {figure}{\numberline {15}{\ignorespaces Mô hình dữ liệu trung tâm của receiver gồm cấu hình gateway, trạng thái sender đã đăng ký, thiết bị lạ và các kết nối TCP đang sống.}}{21}{figure.caption.17}%
\contentsline {figure}{\numberline {16}{\ignorespaces Flowchart phân loại telemetry theo mã thiết bị: sender đã đăng ký được cập nhật vào bảng trạng thái, còn sender chưa đăng ký được đưa vào danh sách thiết bị lạ.}}{22}{figure.caption.18}%
\contentsline {figure}{\numberline {17}{\ignorespaces Flowchart chuyển trạng thái online/offline của sender trên receiver dựa vào timeout.}}{23}{figure.caption.19}%
\contentsline {figure}{\numberline {18}{\ignorespaces Giao diện receiver: tổng quan 2 sender online và trạng thái CoreIoT.}}{24}{figure.caption.20}%
\contentsline {figure}{\numberline {19}{\ignorespaces Chi tiết sender ESP32-01 trên giao diện receiver --- thông tin cơ bản.}}{25}{figure.caption.21}%
