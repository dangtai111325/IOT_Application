\contentsline {figure}{\numberline {33}{\ignorespaces Sơ đồ state machine đồng bộ cấu hình: pending, awaiting ACK, timeout, retry, success/fail.}}{40}{figure.caption.36}%
\contentsline {figure}{\numberline {34}{\ignorespaces Sequence xử lý lỗi RPC khi sender offline và phản hồi lại cloud.}}{40}{figure.caption.37}%
