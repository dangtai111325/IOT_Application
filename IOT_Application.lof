\contentsline {figure}{\numberline {21}{\ignorespaces Dialog cài đặt receiver và CoreIoT.}}{27}{figure.caption.23}%
\contentsline {figure}{\numberline {22}{\ignorespaces Sequence diagram mô tả nhiều sender gửi telemetry lên receiver, receiver cập nhật trạng thái và tiếp tục publish lên cloud.}}{29}{figure.caption.25}%
\contentsline {figure}{\numberline {23}{\ignorespaces Cấu trúc phân cấp topic MQTT Gateway dùng cho tích hợp CoreIoT.}}{30}{figure.caption.26}%
\contentsline {figure}{\numberline {24}{\ignorespaces Sequence diagram mô tả receiver đại diện sender khi gửi connect, telemetry, attribute và xử lý RPC qua MQTT gateway.}}{30}{figure.caption.27}%
\contentsline {figure}{\numberline {25}{\ignorespaces Sequence diagram mô tả quá trình receiver gửi packet cấu hình xuống sender và nhận lại gói xác nhận. Cùng cơ chế này cũng được dùng khi có RPC từ cloud.}}{31}{figure.caption.28}%
\contentsline {figure}{\numberline {26}{\ignorespaces State machine đồng bộ cấu hình giữa receiver và sender.}}{32}{figure.caption.29}%
\contentsline {figure}{\numberline {27}{\ignorespaces Flowchart cơ chế retry cấu hình của receiver khi sender chưa ACK trong thời gian cho phép.}}{33}{figure.caption.30}%
\contentsline {figure}{\numberline {28}{\ignorespaces Gateway dangtai trên CoreIoT với 2 thiết bị ESP32 đang hoạt động.}}{34}{figure.caption.31}%
\contentsline {figure}{\numberline {29}{\ignorespaces Danh sách thiết bị CoreIoT sau khi receiver đăng ký hai sender.}}{34}{figure.caption.32}%
\contentsline {figure}{\numberline {30}{\ignorespaces Dashboard CoreIoT: telemetry và trạng thái AI của hai sender.}}{35}{figure.caption.33}%
\contentsline {figure}{\numberline {31}{\ignorespaces Telemetry ESP32-02 trên CoreIoT --- ai\_score ANOMALY và GPS.}}{35}{figure.caption.34}%
